{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GAN progress state",
  "type": "object",
  "required": [
    "status",
    "currentSprint",
    "totalSprints",
    "completedSprints",
    "currentAttempt",
    "attemptsTotal"
  ],
  "additionalProperties": true,
  "properties": {
    "status": {
      "enum": ["planning", "negotiating", "building", "evaluating", "complete", "failed"]
    },
    "currentSprint": { "type": "integer", "minimum": 0 },
    "totalSprints": { "type": "integer", "minimum": 0 },
    "completedSprints": { "type": "integer", "minimum": 0 },
    "currentAttempt": { "type": "integer", "minimum": 0 },
    "attemptsTotal": { "type": "integer", "minimum": 0 },
    "startedAt": { "type": ["string", "null"] },
    "startingBranch": { "type": ["string", "null"] },
    "failureReason": { "type": ["string", "null"] }
  }
}
