{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GAN contract review verdict",
  "type": "object",
  "required": ["sprintNumber", "verdict", "notes"],
  "additionalProperties": false,
  "properties": {
    "sprintNumber": { "type": "integer", "minimum": 1 },
    "verdict": { "enum": ["approved", "revise"] },
    "notes": { "type": "string" }
  }
}
