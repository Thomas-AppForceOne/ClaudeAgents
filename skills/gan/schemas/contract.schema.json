{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GAN sprint contract",
  "type": "object",
  "required": ["sprintNumber", "features", "criteria"],
  "additionalProperties": false,
  "properties": {
    "sprintNumber": { "type": "integer", "minimum": 1 },
    "features": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "threshold"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_]+$"
          },
          "description": { "type": "string", "minLength": 1 },
          "threshold": { "type": "integer", "minimum": 1, "maximum": 10 }
        }
      }
    }
  }
}
